# Database
DATABASE_URL=postgresql+asyncpg://tollgate:tollgate@localhost:5432/tollgate

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_DAYS=7

# API Key HMAC Secret (for fast API key verification - NOT bcrypt)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY_HMAC_SECRET=your-api-key-hmac-secret-change-in-production

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
